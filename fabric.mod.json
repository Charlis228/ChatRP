{
  "schemaVersion": 1,
  "id": "chatrp",
  "version": "1.0.0",
  "name": "ChatRp",
  "description": "ChatRp - единый русский мод чата: RP вкладки, головы игроков, история, фильтры, поиск и расширенный HUD.",
